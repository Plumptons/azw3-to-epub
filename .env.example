# Shared media tree (same host bind Bindery + Storyteller use)
MEDIA_DIR=M:/media

DELETE_SOURCE=false
INITIAL_SCAN=true
# Full-tree AZW3 poll (Docker/Windows mounts often miss watchdog events)
RESCAN_INTERVAL=120
STABLE_SECONDS=5
LOG_LEVEL=INFO
TZ=Pacific/Auckland
PUID=0
PGID=0

# --- Bindery ebook-link cleanup ---
BINDERY_URL=http://bindery:8787
BINDERY_API_KEY=
BINDERY_SYNC=true
BINDERY_LIBRARY_DIR=/media/books
# Trigger Bindery Wanted search+grab more often than Bindery's ~12h scheduler
BINDERY_WANTED_SEARCH=true
BINDERY_SEARCH_INTERVAL=3600
# For monitored books with ebook but no audiobook (mediaType ebook or both):
# search for audiobooks; keep/set both if releases exist, otherwise set ebook
BINDERY_AUDIO_PROBE=true
BINDERY_AUDIO_PROBE_INTERVAL=3600
# Max books to probe per sweep (indexer-friendly)
BINDERY_AUDIO_PROBE_LIMIT=5
# Seconds before re-probing the same book after no-audio (default 7 days)
BINDERY_AUDIO_PROBE_COOLDOWN=604800
# Merge Bindery "Title (Year) (2)" sibling folders into the primary folder
FOLDER_COALESCE=true
FOLDER_COALESCE_INTERVAL=300

# --- Storyteller auto-merge ebook + audiobook ---
# Same Docker network: container port 8001 (host maps 8886:8001)
# Separate compose: http://192.168.0.48:8886
STORYTELLER_URL=http://storyteller:8001
STORYTELLER_USERNAME=
STORYTELLER_PASSWORD=
STORYTELLER_AUTO_MERGE=true
# Seconds between full library merge sweeps (also runs after each convert)
STORYTELLER_MERGE_INTERVAL=300
# Wait after convert so Storyteller auto-import can see the new EPUB
STORYTELLER_MERGE_DELAY=15

# Calibre output: 2 (widest compatibility) or 3 (better for Storyteller)
EPUB_VERSION=3
